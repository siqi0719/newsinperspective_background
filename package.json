{
  "name": "news-in-perspective",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "api:start": "pnpm --filter @news/api start",
    "build": "turbo run build",
    "db:start": "docker compose up -d postgres",
    "dev": "turbo run dev",
    "drive:pull": "bash scripts/google-drive/pull.sh",
    "drive:push": "bash scripts/google-drive/push.sh",
    "drive:status": "bash scripts/google-drive/status.sh",
    "enrich:status": "pnpm --filter @news/api enrich:status",
    "enrich:text": "pnpm --filter @news/api enrich:text",
    "export:kagi:notebook": "python3 notebooks/src/consolidate_kagi_exports.py",
    "export:notebook": "python3 notebooks/src/export_news_slice.py",
    "ingest": "pnpm --filter @news/api ingest",
    "kagi:export-clusters": "pnpm --filter @news/api kagi:export-clusters",
    "kagi:backfill-redirects": "pnpm --filter @news/api kagi:backfill-redirects",
    "kagi:repair-failures": "pnpm --filter @news/api kagi:repair-failures",
    "kagi:random-cluster": "pnpm --filter @news/api kagi:random-cluster",
    "kagi:top-clusters": "pnpm --filter @news/api kagi:top-clusters",
    "data:status": "pnpm --filter @news/api status",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "verify:text-enrichment": "pnpm --filter @news/api verify:text-enrichment",
    "db:generate": "pnpm --filter @news/db db:generate",
    "db:migrate": "pnpm --filter @news/db db:migrate",
    "db:deploy": "pnpm --filter @news/db db:deploy",
    "web:start": "pnpm --filter @news/web dev -- --host 0.0.0.0"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.8.2"
  }
}
