generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RunStatus {
  PENDING
  SUCCESS
  PARTIAL
  FAILED
}

enum ScopeType {
  ARTICLE
  CLUSTER
}

enum ExtractionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum EntityType {
  PERSON
  GPE
  ORG
  EVENT
}

model FeedSource {
  id          String      @id @default(cuid())
  url         String      @unique
  category    String?
  sourceName  String?
  domain      String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  fetches     FeedFetch[]
  articles    Article[]
}

model IngestionRun {
  id             String       @id @default(cuid())
  ingestionDate  DateTime
  status         RunStatus    @default(PENDING)
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  feedCount      Int          @default(0)
  articleCount   Int          @default(0)
  clusterCount   Int          @default(0)
  errorSummary   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feedFetches    FeedFetch[]

  @@unique([ingestionDate])
}

model FeedFetch {
  id             String        @id @default(cuid())
  runId          String
  feedSourceId   String
  statusCode     Int?
  ok             Boolean       @default(false)
  fetchedAt      DateTime      @default(now())
  errorMessage   String?
  rawHash        String?
  itemCount      Int           @default(0)
  run            IngestionRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  feedSource     FeedSource    @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)
  raws           ArticleRaw[]

  @@unique([runId, feedSourceId])
}

model Article {
  id              String           @id @default(cuid())
  canonicalUrl    String           @unique
  originalUrl     String
  textFingerprint String?          @unique
  title           String
  summary         String?
  contentSnippet  String?
  fullText        String?
  fullTextFormat  String?
  extractionStatus ExtractionStatus @default(PENDING)
  extractedAt     DateTime?
  extractionError String?
  publishedAt     DateTime?
  sourceName      String
  domain          String
  duplicateDomains String[]
  duplicateCount  Int              @default(0)
  language        String?
  category        String?
  ingestionDate   DateTime
  authorNames     String[]
  feedSourceId    String?
  feedSource      FeedSource?      @relation(fields: [feedSourceId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  raws            ArticleRaw[]
  clusterLinks    ClusterArticle[]
  features        NlpFeature[]
  entityMentions  EntityMention[]  // 该文章中识别的实体

  @@index([textFingerprint])
}

model ArticleRaw {
  id           String     @id @default(cuid())
  articleId    String?
  feedFetchId  String
  payload      Json
  article      Article?   @relation(fields: [articleId], references: [id], onDelete: SetNull)
  feedFetch    FeedFetch  @relation(fields: [feedFetchId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model StoryCluster {
  id            String           @id @default(cuid())
  clusterKey    String
  storyDate     DateTime
  title         String
  topCategory   String?
  articleCount  Int              @default(0)
  sourceCount   Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  articles      ClusterArticle[]
  features      NlpFeature[]

  @@unique([clusterKey, storyDate])
}

model ClusterArticle {
  id             String        @id @default(cuid())
  clusterId      String
  articleId      String
  rank           Int           @default(0)
  similarity     Float         @default(0)
  cluster        StoryCluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  article        Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([clusterId, articleId])
}

model SourceProfile {
  id                String     @id @default(cuid())
  domain            String     @unique
  sourceName        String
  articleCount      Int        @default(0)
  averageSentiment  Float      @default(0)
  commonBiasSignals String[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model NlpFeature {
  id         String      @id @default(cuid())
  scopeType  ScopeType
  articleId  String?
  clusterId  String?
  featureSet Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  article    Article?    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  cluster    StoryCluster? @relation(fields: [clusterId], references: [id], onDelete: Cascade)
}

// ============================================================
// 背景信息功能：命名实体识别和 Wikipedia 链接
// ============================================================

// 主实体表：存储识别的命名实体（人名、地名、组织、事件等）
model NamedEntity {
  id                String      @id @default(cuid())
  name              String      @unique // 实体名称，唯一
  type              EntityType  // PERSON, GPE, ORG, EVENT
  wikiId            String?     @unique // Wikipedia 文章 ID
  wikipediaUrl      String?     // Wikipedia 链接
  wikidataId        String?     // Wikidata ID（提供结构化数据）
  summary           String?     @db.Text // Wikipedia 摘要
  imageUrl          String?     // 实体图片 URL
  infoboxJson       Json?       // Wikipedia 信息框的结构化数据
  firstSeen         DateTime    @default(now()) // 首次被识别的时间
  lastUpdated       DateTime    @updatedAt // 最后更新时间

  // 关系
  mentions          EntityMention[]
  statistics        EntityStatistics?
  cooccurrence1     EntityCooccurrence[] @relation("entity1")
  cooccurrence2     EntityCooccurrence[] @relation("entity2")

  @@index([name]) // 为搜索优化
  @@index([type]) // 为类型过滤优化
}

// 实体提及表：记录实体在文章中的具体位置
model EntityMention {
  id                String      @id @default(cuid())
  entityId          String
  entity            NamedEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  articleId         String
  article           Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)

  startOffset       Int         // 实体在文本中的开始字符位置
  endOffset         Int         // 实体在文本中的结束字符位置
  context           String      // 周围 50 个字的上下文（用于展示）
  confidence        Float?      // NER 模型的置信度 (0-1)

  createdAt         DateTime    @default(now())

  @@index([entityId])
  @@index([articleId])
  @@index([confidence]) // 为低置信度查询优化
}

// 实体统计表：缓存实体的统计数据（避免每次查询都重新计算）
model EntityStatistics {
  id                String      @id @default(cuid())
  entityId          String      @unique
  entity            NamedEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  totalMentions     Int         @default(0)     // 总提及次数
  uniqueArticles    Int         @default(0)     // 包含该实体的文章数
  mentions7Days     Int         @default(0)     // 过去 7 天的提及次数
  mentions30Days    Int         @default(0)     // 过去 30 天的提及次数
  averagePosition   Float?      // 实体在文章中的平均位置 (0-1，0=开头，1=结尾)
  lastUpdated       DateTime    @updatedAt
}

// 实体共现关系表：记录哪些实体经常一起出现
model EntityCooccurrence {
  id                String      @id @default(cuid())
  entity1Id         String
  entity1           NamedEntity @relation("entity1", fields: [entity1Id], references: [id], onDelete: Cascade)
  entity2Id         String
  entity2           NamedEntity @relation("entity2", fields: [entity2Id], references: [id], onDelete: Cascade)

  cooccurrenceCount Int         @default(0)     // 共现次数
  lastDate          DateTime    @default(now()) // 最后共现日期

  @@unique([entity1Id, entity2Id]) // 防止重复关系
  @@index([entity1Id])
  @@index([entity2Id])
}

