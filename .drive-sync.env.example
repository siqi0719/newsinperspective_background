# Google Drive sync configuration for the notebooks workspace.
#
# Copy to `.drive-sync.env` and set one of the modes below.
#
# Mode 1: mounted/local Google Drive folder
# NEWS_NOTEBOOKS_DRIVE_DIR="/path/to/Google Drive/NewsInPerspective/notebooks"
#
# Mode 2: rclone remote
# NEWS_NOTEBOOKS_GDRIVE_REMOTE="gdrive"
# NEWS_NOTEBOOKS_GDRIVE_PATH="NewsInPerspective/notebooks"
#
# Optional:
# NEWS_NOTEBOOKS_SYNC_DELETE="false"
